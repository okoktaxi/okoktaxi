<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DropTaxi | Book Your Ride</title>
  <!-- Font Awesome 6 (free) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    body {
      background: #fefefe;
      color: #1f1f1f;
      line-height: 1.5;
    }

    /* yellow/black theme variables */
    :root {
      --taxi-yellow: #f5b81b;
      --taxi-black: #1e1e1e;
      --taxi-yellow-light: #ffe28c;
      --taxi-grey: #f4f4f4;
      --shadow-sm: 0 8px 20px rgba(0,0,0,0.06);
      --shadow-hover: 0 16px 30px rgba(0,0,0,0.12);
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ===== hero section ===== */
    .hero {
      background: linear-gradient(105deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.65) 100%), 
                  url('https://images.unsplash.com/photo-1591439657848-5f6e57d0c03a?q=80&w=2070&auto=format&fit=crop') center/cover no-repeat;
      min-height: 580px;
      display: flex;
      align-items: center;
      border-bottom: 6px solid var(--taxi-yellow);
    }

    .hero-content {
      color: white;
      max-width: 650px;
      padding: 60px 0;
    }

    .hero-content h1 {
      font-size: 3.5rem;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 0.5rem;
      text-shadow: 2px 2px 0 rgba(0,0,0,0.3);
    }

    .hero-content .subhead {
      font-size: 1.5rem;
      margin-bottom: 2rem;
      opacity: 0.95;
      font-weight: 400;
    }

    .hero-buttons {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 14px 36px;
      border-radius: 50px;
      font-weight: 600;
      font-size: 1.1rem;
      border: none;
      cursor: pointer;
      transition: all 0.25s ease;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--taxi-yellow);
      color: var(--taxi-black);
      box-shadow: 0 4px 14px rgba(245, 184, 27, 0.4);
    }

    .btn-primary:hover {
      background: #ffcf4d;
      transform: scale(1.03);
      box-shadow: 0 8px 22px rgba(245, 184, 27, 0.5);
    }

    .btn-whatsapp {
      background: #25D366;
      color: white;
    }

    .btn-whatsapp:hover {
      background: #20bd5a;
      transform: scale(1.03);
    }

    /* ===== booking form section ===== */
    .booking-panel {
      background: white;
      border-radius: 32px;
      box-shadow: var(--shadow-sm);
      padding: 40px 30px;
      margin-top: -70px;
      margin-bottom: 40px;
      position: relative;
      z-index: 10;
      border: 1px solid rgba(0,0,0,0.03);
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px 25px;
      margin-top: 15px;
    }

    .input-field {
      display: flex;
      flex-direction: column;
    }

    .input-field label {
      font-weight: 600;
      font-size: 0.95rem;
      margin-bottom: 6px;
      color: #2b2b2b;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .input-field label i {
      color: var(--taxi-yellow);
      width: 20px;
    }

    .input-field input, .input-field select {
      padding: 14px 16px;
      border: 1.5px solid #e2e2e2;
      border-radius: 18px;
      font-size: 1rem;
      transition: 0.2s;
      background: #fafafa;
    }

    .input-field input:focus, .input-field select:focus {
      border-color: var(--taxi-yellow);
      outline: none;
      background: white;
      box-shadow: 0 0 0 3px rgba(245,184,27,0.2);
    }

    .get-fare-btn {
      background: var(--taxi-black);
      color: white;
      border: none;
      padding: 16px 28px;
      border-radius: 40px;
      font-weight: 700;
      font-size: 1.2rem;
      cursor: pointer;
      transition: 0.2s;
      margin-top: 26px;
      width: fit-content;
      min-width: 220px;
      border: 2px solid var(--taxi-yellow);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .get-fare-btn:hover {
      background: #2f2f2f;
      transform: translateY(-3px);
      box-shadow: 0 15px 25px -5px rgba(0,0,0,0.2);
    }

    /* section headings */
    .section-title {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 2rem;
      position: relative;
      display: inline-block;
    }
    .section-title:after {
      content: '';
      display: block;
      width: 60%;
      height: 5px;
      background: var(--taxi-yellow);
      border-radius: 6px;
      margin-top: 10px;
    }
    .text-center .section-title:after {
      margin-left: auto;
      margin-right: auto;
    }

    /* cards grid */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 30px;
      margin: 40px 0;
    }

    .service-card, .route-card, .feature-card, .car-card, .review-card {
      background: white;
      border-radius: 28px;
      padding: 28px 18px;
      text-align: center;
      box-shadow: var(--shadow-sm);
      transition: all 0.25s ease;
      border: 1px solid rgba(0,0,0,0.02);
    }

    .service-card:hover, .route-card:hover, .feature-card:hover, .car-card:hover, .review-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-hover);
      border-color: var(--taxi-yellow);
    }

    .service-card i, .feature-card i, .car-card i, .review-card i {
      font-size: 2.6rem;
      color: var(--taxi-yellow);
      margin-bottom: 15px;
    }

    .route-card {
      background: var(--taxi-black);
      color: white;
    }
    .route-card i {
      color: var(--taxi-yellow);
      font-size: 2rem;
      background: rgba(255,255,255,0.1);
      padding: 12px;
      border-radius: 60%;
    }
    .route-card h3 {
      font-weight: 500;
      letter-spacing: 0.5px;
    }

    .feature-card {
      background: var(--taxi-grey);
      border-radius: 30px;
    }

    /* review card special */
    .review-card {
      background: #ffffff;
      text-align: left;
      padding: 26px;
    }
    .review-card .stars {
      color: var(--taxi-yellow);
      margin-bottom: 10px;
      font-size: 1.1rem;
    }
    .review-card p {
      font-style: italic;
      margin-bottom: 15px;
    }
    .review-card h4 {
      font-weight: 700;
    }

    /* footer */
    .footer {
      background: var(--taxi-black);
      color: #ddd;
      padding: 60px 0 30px;
      margin-top: 60px;
      border-top: 5px solid var(--taxi-yellow);
    }

    .footer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 40px;
    }

    .footer-item {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 1.2rem;
    }
    .footer-item i {
      color: var(--taxi-yellow);
      font-size: 1.8rem;
      min-width: 40px;
    }
    .footer a {
      color: white;
      text-decoration: none;
      transition: 0.2s;
    }
    .footer a:hover {
      color: var(--taxi-yellow);
    }
    .copyright {
      text-align: center;
      margin-top: 50px;
      color: #888;
    }

    /* mobile first adjustments */
    @media (max-width: 768px) {
      .hero-content h1 {
        font-size: 2.5rem;
      }
      .booking-panel {
        margin-top: -40px;
        padding: 30px 20px;
      }
      .get-fare-btn {
        width: 100%;
        justify-content: center;
      }
      .section-title {
        font-size: 2rem;
      }
    }
    @media (max-width: 480px) {
      .hero-buttons .btn {
        width: 100%;
        justify-content: center;
      }
    }

    /* hover & helper */
    .mt-2 { margin-top: 10px; }
    .mb-3 { margin-bottom: 30px; }
    .text-center { text-align: center; }
  </style>
</head>
<body>

<!-- HERO SECTION -->
<section class="hero">
  <div class="container hero-content">
    <h1>Book Your Taxi <br>in Minutes</h1>
    <p class="subhead">Safe, Affordable and Reliable Taxi Service</p>
    <div class="hero-buttons">
      <button class="btn btn-primary"><i class="fas fa-taxi"></i> Call now</button>
      <a href="#" class="btn btn-whatsapp"><i class="fab fa-whatsapp"></i> WhatsApp</a>
    </div>
  </div>
</section>

<!-- TAXI BOOKING FORM -->
<div class="container">
  <div class="booking-panel">
    <h2 style="font-size: 2rem; margin-bottom: 15px;">📋 Book your ride</h2>
    <div class="form-grid">
      <div class="input-field"><label><i class="fas fa-map-pin"></i> Pickup Location</label><input type="text" placeholder="e.g. Egmore, Chennai"></div>
      <div class="input-field"><label><i class="fas fa-location-dot"></i> Drop Location</label><input type="text" placeholder="e.g. Pondicherry"></div>
      <div class="input-field"><label><i class="fas fa-calendar"></i> Pickup Date</label><input type="date" value="2025-04-10"></div>
      <div class="input-field"><label><i class="fas fa-clock"></i> Pickup Time</label><input type="time" value="08:30"></div>
      <div class="input-field"><label><i class="fas fa-route"></i> Trip Type</label>
        <select>
          <option>One Way</option>
          <option>Round Trip</option>
        </select>
      </div>
      <div class="input-field"><label><i class="fas fa-user"></i> Name</label><input type="text" placeholder="Your name"></div>
      <div class="input-field"><label><i class="fas fa-phone-alt"></i> Phone Number</label><input type="tel" placeholder="+91 98765 43210"></div>
    </div>
    <button class="get-fare-btn"><i class="fas fa-calculator"></i> Get Fare</button>
  </div>
</div>

<!-- SERVICES SECTION -->
<div class="container">
  <h2 class="section-title">Our Services</h2>
  <div class="card-grid">
    <div class="service-card"><i class="fas fa-arrow-right"></i><h3>One Way Drop Taxi</h3><p>Outstation one-way drops</p></div>
    <div class="service-card"><i class="fas fa-exchange-alt"></i><h3>Round Trip Taxi</h3><p>Return journeys</p></div>
    <div class="service-card"><i class="fas fa-plane-departure"></i><h3>Airport Pickup & Drop</h3><p>MAA / shuttle</p></div>
  </div>
</div>

<!-- POPULAR ROUTES -->
<div class="container" style="margin-top: 50px;">
  <h2 class="section-title">Popular Routes</h2>
  <div class="card-grid">
    <div class="route-card"><i class="fas fa-map-marked-alt"></i><h3>Chennai to Pondicherry</h3><p>160 km • 4 hrs</p></div>
    <div class="route-card"><i class="fas fa-map-marked-alt"></i><h3>Chennai to Tirupati</h3><p>140 km • 3.5 hrs</p></div>
    <div class="route-card"><i class="fas fa-map-marked-alt"></i><h3>Chennai to Bangalore</h3><p>350 km • 7 hrs</p></div>
    <div class="route-card"><i class="fas fa-map-marked-alt"></i><h3>Chennai to Vellore</h3><p>140 km • 3 hrs</p></div>
  </div>
</div>

<!-- WHY CHOOSE US + FEATURES -->
<div class="container" style="margin-top: 50px;">
  <h2 class="section-title">Why Choose Us</h2>
  <div class="card-grid">
    <div class="feature-card"><i class="fas fa-clock"></i><h3>24/7 Service</h3><p>Always ready to ride</p></div>
    <div class="feature-card"><i class="fas fa-id-card"></i><h3>Verified Drivers</h3><p>Background checked</p></div>
    <div class="feature-card"><i class="fas fa-tag"></i><h3>Best Price Guarantee</h3><p>No hidden charges</p></div>
    <div class="feature-card"><i class="fas fa-spray-can-sparkles"></i><h3>Clean & Comfortable Cars</h3><p>Sanitized rides</p></div>
  </div>
</div>

<!-- CAR TYPES -->
<div class="container" style="margin-top: 50px;">
  <h2 class="section-title">Car Types</h2>
  <div class="card-grid">
    <div class="car-card"><i class="fas fa-car-side"></i><h3>Sedan</h3><p>Swift, Dzire, Etios</p></div>
    <div class="car-card"><i class="fas fa-truck-pickup"></i><h3>SUV</h3><p>XUV, Crysta</p></div>
    <div class="car-card"><i class="fas fa-van-shuttle"></i><h3>Innova</h3><p>7 seater, spacious</p></div>
  </div>
</div>

<!-- CUSTOMER REVIEWS -->
<div class="container" style="margin-top: 50px;">
  <h2 class="section-title">Customer Reviews</h2>
  <div class="card-grid">
    <div class="review-card">
      <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
      <p>“Very professional, on time, car was super clean. Will book again.”</p>
      <h4>— Ravi S.</h4>
    </div>
    <div class="review-card">
      <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i></div>
      <p>“Smooth Chennai to Bangalore trip. Driver knew the route well.”</p>
      <h4>— Priya K.</h4>
    </div>
    <div class="review-card">
      <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
      <p>“Best price and friendly service. Highly recommend.”</p>
      <h4>— Arun M.</h4>
    </div>
  </div>
</div>

<!-- FOOTER with contact & location -->
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-item"><i class="fas fa-phone-alt"></i> <span>+91 98765 43210</span></div>
      <div class="footer-item"><i class="fab fa-whatsapp"></i> <a href="#">+91 98765 43210 (WhatsApp)</a></div>
      <div class="footer-item"><i class="fas fa-envelope"></i> <a href="mailto:book@droptaxi.in">book@droptaxi.in</a></div>
      <div class="footer-item"><i class="fas fa-map-marker-alt"></i> No.42, Anna Salai, Chennai - 600002</div>
    </div>
    <div class="copyright">
      <p>© 2025 DropTaxi — reliable rides, every time.</p>
    </div>
  </div>
</footer>

<!-- small JS for interactivity (console log, hover not needed) -->
<script>
  (function() {
    // just a simple console to show that js is loaded, and enhance "Get Fare" click
    const fareBtn = document.querySelector('.get-fare-btn');
    if(fareBtn) {
      fareBtn.addEventListener('click', function(e){
        e.preventDefault();
        alert('Fare estimate feature coming soon! (demo)');
      });
    }
    // make call button and whatsapp demo alert
    const callBtn = document.querySelector('.btn-primary');
    const waBtn = document.querySelector('.btn-whatsapp');
    if(callBtn) callBtn.addEventListener('click', ()=> alert('Call us at +91 98765 43210'));
    if(waBtn) waBtn.addEventListener('click', (e)=> { e.preventDefault(); alert('WhatsApp chat opens demo.'); });
  })();
</script>

</body>
</html>
